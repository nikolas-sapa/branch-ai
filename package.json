{
  "name": "branch-ai",
  "version": "0.5.0",
  "description": "A collaborative canvas for AI reasoning. Wraps the Claude Code CLI to capture extended thinking as a navigable, forkable tree.",
  "type": "module",
  "bin": {
    "branch": "dist/cli.js",
    "branch-mcp": "dist/mcp.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/cli.js && chmod +x dist/mcp.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "viewer": "cd viewer && npm install && npm run dev",
    "prepublishOnly": "npm run build && npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/84yk8btb9f-prog/branch-ai.git"
  },
  "bugs": "https://github.com/84yk8btb9f-prog/branch-ai/issues",
  "homepage": "https://github.com/84yk8btb9f-prog/branch-ai#readme",
  "keywords": [
    "claude",
    "claude-code",
    "anthropic",
    "mcp",
    "reasoning",
    "extended-thinking",
    "ai-agents",
    "llm",
    "cli"
  ],
  "author": "Nikolas Sapalidis",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@vercel/blob": "^2.3.3",
    "execa": "^9.5.0",
    "nanoid": "^5.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
